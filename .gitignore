node_modules/
.pnp
.pnp.*
.npm/
.pnpm-store/
.pnpm-debug.log*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
bower_components/
jspm_packages/
vendor/

# ------------------------------------------------------------
# Build output, framework caches, reports
# Covers JavaScript / TypeScript / Next.js / common frontend tools
# ------------------------------------------------------------
.next/
out/
build/
dist/
coverage/
.cache/
.parcel-cache/
.turbo/
.vite/
.svelte-kit/
.nuxt/
.angular/
storybook-static/
*.tsbuildinfo
next-env.d.ts
.shots/

# ------------------------------------------------------------
# Environment files and local secrets
# Keep example env files committed separately if needed
# ------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
*.local
*.secret
*.secrets

# ------------------------------------------------------------
# Logs, temp files, diagnostics
# ------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*
*.pid
*.pid.lock
*.seed
*.stackdump
tmp/
temp/
.tmp/

